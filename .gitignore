# Build outputs
/bin/
/growcore/growcore
/growcore/growcore-bin

# SQLite databases
*.db
*.db-journal
*.db-wal
*.db-shm
/growcore/environments/*/cameras/
/growcore/*.db.cameras/

# Embedded web build — populated by `make build`, only the placeholder is tracked
/growcore/internal/webui/dist/*
!/growcore/internal/webui/dist/.gitkeep

# Embedded device catalogue — synced from /devices by `make build`; the
# authoritative source is /devices, only the placeholder is tracked here
/growcore/internal/catalog/data/*
!/growcore/internal/catalog/data/.gitkeep

# Embedded integration bundles and the local credential-encryption key.
/growcore/internal/integrations/data/*
!/growcore/internal/integrations/data/.gitkeep
**/.integration-secret-key

# Node / SvelteKit
node_modules/
/web/.svelte-kit/
/web/build/

# Environment files (secrets); keep the example
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.claude
